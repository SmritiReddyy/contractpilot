SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

ANTHROPIC_API_KEY=sk-ant-...

# ── Email (choose ONE option) ─────────────────────────────
#
# Option 1 — Resend (recommended, resend.com)
#   Free tier: 3,000 emails/month
#   From address: use onboarding@resend.dev while testing,
#                 your own domain once verified in Resend dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev
#
# Option 2 — Gmail SMTP (only used if RESEND_API_KEY is empty)
#   Requires a Gmail App Password (myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=you@gmail.com
# ─────────────────────────────────────────────────────────

SECRET_KEY=supersecretkey-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
